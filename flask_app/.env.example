# GENRI LABS — environment template
# Copy to .env for local dev. On cPanel, set these in
# Setup Python App > Environment Variables instead (no .env file on server).

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-char-hex

# Where expired sessions get redirected
PUBLIC_SITE_URL=https://genrilabs.com

# cPanel MySQL credentials (Databases > MySQL Databases)
DB_HOST=localhost
DB_NAME=cpaneluser_genrilabs
DB_USER=cpaneluser_gladmin
DB_PASSWORD=replace-me
